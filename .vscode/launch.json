{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Wrapper",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\wrapper\\index.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Gateway",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\gateway\\index.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Client Gateway",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/client/index.js",
            "args": ["--auth", "--user", "${input:mcpUser}", "--pass", "${input:mcpPass}"]
        }
    ],
    "inputs": [
        {
            "id": "mcpUser",
            "type": "promptString",
            "description": "Keycloak username",
            "default": "mcp-admin"
        },
        {
            "id": "mcpPass",
            "type": "promptString",
            "description": "Keycloak password",
            "default": "admin123"
        }
    ]
}