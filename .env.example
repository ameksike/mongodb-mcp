# MongoDB MCP core
MDB_MCP_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net
MDB_MCP_TRANSPORT=http
MDB_MCP_HTTP_HOST=127.0.0.1
MDB_MCP_HTTP_PORT=8000
MDB_MCP_HTTP_BODY_RESPONSE_TYPE=json

# Hard security defaults
MDB_MCP_READ_ONLY=true
MDB_MCP_DISABLED_TOOLS=create,update,delete,atlas

# Optional hardening
MDB_MCP_INDEX_CHECK=false
MDB_MCP_TELEMETRY=enabled

# Logging / exports (optional; can be omitted)
MDB_MCP_LOGGERS=disk
MDB_MCP_LOG_PATH=/var/log/mongodb-mcp
MDB_MCP_EXPORTS_PATH=/var/lib/mongodb-mcp/exports